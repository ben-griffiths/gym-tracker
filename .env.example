NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# OAuth + email confirmations: must list these under Supabase → Authentication → URL configuration → Redirect URLs.
# Include e.g. http://localhost:3000/auth/callback and https://YOUR_PROD_DOMAIN/auth/callback.
# Missing localhost URLs often yields a bounce to your project's Site URL (production).
# OPTIONAL: Pin origin if it must match Redirect URLs exactly (localhost vs 127.0.0.1 vs LAN URL):
# NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN="http://localhost:3000"

OPENAI_API_KEY=""
# Step 1: vision — describe equipment and suggest exercise names in natural language.
OPENAI_VISION_DESCRIBE_MODEL="gpt-4.1"
# Step 2: text — map that output to exercise slugs from the catalog.
OPENAI_VISION_MATCH_MODEL="gpt-4.1-mini"

# E2E (Playwright): optional override for `x-gym-playwright-bypass` header / dev middleware (default: local-playwright-e2e).
# PLAYWRIGHT_E2E_BYPASS_SECRET="local-playwright-e2e"


# Optional: require this value in the `x-webllm-log-secret` header for POST /api/webllm-log (reduces spam).
# Set the same string here and in your deployment env so the client can send crash diagnostics.
# NEXT_PUBLIC_WEBLLM_LOG_INGEST_SECRET=""
# Log full JSON payloads in production (default: one-line summary unless NODE_ENV=development).
# WEBLLM_LOG_VERBOSE="1"

# Optional: force main-thread WebLLM only (no Web Worker). Useful if production worker chunks fail to load.
# NEXT_PUBLIC_WEBLLM_SKIP_WORKER="1"

# [webllm] Browser console: [webllm] logs on by default. Opt out: localStorage "gym.webllm.log"=0, or:
# NEXT_PUBLIC_WEBLLM_LOG="0"
# (rebuild when changing NEXT_PUBLIC_*). In-page: localStorage.setItem("gym.webllm.log", "0"); location.reload();
