NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

OPENAI_API_KEY=""
# Step 1: vision — describe equipment and suggest exercise names in natural language.
OPENAI_VISION_DESCRIBE_MODEL="gpt-4.1"
# Step 2: text — map that output to exercise slugs from the catalog.
OPENAI_VISION_MATCH_MODEL="gpt-4.1-mini"

# In-browser workout chat (WebLLM + WebGPU). If unset, the app picks a model at runtime:
#   — desktop: Hermes-2-Pro-Llama-3-8B-q4f16_1-MLC
#   — phone / tablet, Save-Data, or deviceMemory ≤4: Hermes-2-Pro-Mistral-7B-q4f16_1-MLC + smaller context
# Override with any prebuilt model_id from the installed @mlc-ai/web-llm (see MLC / WebLLM docs).
# NEXT_PUBLIC_WEBLLM_MODEL="Hermes-2-Pro-Llama-3-8B-q4f16_1-MLC"
# Lighter option if mobile WebGPU is unstable (closer to chat.webllm.mlc.ai small models):
# NEXT_PUBLIC_WEBLLM_MODEL="Llama-3.2-1B-Instruct-q4f32_1-MLC"
